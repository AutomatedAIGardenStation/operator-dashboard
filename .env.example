# GardenStation Frontend Environment Variables Template
# Copy this file to .env and configure for your local environment.

# API Base URL for REST requests
# Default: http://localhost:8000/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# WebSocket URL for real-time sensor/actuator data
# Default: http://garden.local:8000
VITE_WS_URL=http://garden.local:8000
